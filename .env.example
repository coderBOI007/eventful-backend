# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000

# ─── Database ────────────────────────────────────────────────────────────────
DB_URL=postgresql://user:password@localhost:5432/eventful

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_here_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Paystack ────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_your_secret_key
PAYSTACK_PUBLIC_KEY=pk_live_your_public_key
PAYSTACK_WEBHOOK_HASH=your_webhook_hash_from_paystack_dashboard

# ─── SMTP (for reminder emails) ──────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ─── App ─────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:3000

# ─── QR Code signing secret ──────────────────────────────────────────────────
QR_HMAC_SECRET=your_qr_hmac_secret_change_in_production